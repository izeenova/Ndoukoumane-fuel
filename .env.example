# Base de données Neon (PostgreSQL)
# Créez un compte sur https://neon.tech et copiez votre DATABASE_URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth - Générez un secret avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-tres-securise-ici"
NEXTAUTH_URL="http://localhost:3000"

# En production sur Vercel, NEXTAUTH_URL sera automatiquement configuré
